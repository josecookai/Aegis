PORT=3000
BASE_URL=http://localhost:3000
DB_PATH=./data/aegis.db
EMAIL_FROM=no-reply@aegis.local
WEBHOOK_SIGNING_SECRET=dev_global_secret
AUTO_START_WORKERS=true
ADMIN_PASSWORD=aegis_admin_dev
ADMIN_SESSION_SECRET=change_me_before_shared_env
APP_SESSION_SECRET=change_me_before_shared_env

# Stripe (optional — leave empty to use mock payments)
# Get your test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# End-user Auth (optional)
PASSWORD_HASH_PEPPER=change_me_before_shared_env
AUTH_OAUTH_STATE_TTL_MINUTES=10

# Google OAuth (optional)
# Callback URL (local): http://localhost:3000/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# GitHub OAuth (optional)
# Callback URL (local): http://localhost:3000/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
